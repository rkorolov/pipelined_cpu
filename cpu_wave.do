onerror {resume}
radix define boolean {
    "1'b0" "false" -color "red",
    "1'b1" "true" -color "green",
    -default default
}
radix define cntrl_sig {
    "3'b000" "B" -color "yellow",
    "3'b010" "ADD" -color "green",
    "3'b011" "SUB" -color "red",
    "3'b100" "AND" -color "cyan",
    "3'b101" "OR" -color "magenta",
    "3'b110" "XOR" -color "orange",
    -default default
}
radix define mem_reg_sig {
    "2'b00" "ALU Result" -color "yellow",
    "2'b01" "Memory Access" -color "green",
    "2'b10" "PC+4" -color "red",
    -default default
}
